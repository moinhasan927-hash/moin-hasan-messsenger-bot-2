const login = require("facebook-chat-api");
const fs = require("fs");
const { GoogleGenerativeAI } = require("@google/generative-ai");

// Gemini AI Setup
const genAI = new GoogleGenerativeAI("AIzaSyCTrcORx03Lvt2I94xGIu2MVZmXL-PZvd0");
const model = genAI.getGenerativeModel({ model: "gemini-pro" });

// Messenger Bot Setup
login({appState: JSON.parse(fs.readFileSync('appstate.json', 'utf8'))}, (err, api) => {
    if(err) return console.error(err);

    api.setOptions({listenEvents: true});

    console.log("বট চালু হয়েছে! এখন গ্রুপে মেসেজ দিলে উত্তর দিবে।");

    api.listenMqtt(async (err, event) => {
        if(err) return console.error(err);

        if(event.type === "message" && event.body) {
            try {
                // Gemini থেকে উত্তর নেওয়া
                const result = await model.generateContent(event.body);
                const response = await result.response;
                const text = response.text();

                // গ্রুপে রিপ্লাই দেওয়া
                api.sendMessage(text, event.threadID);
            } catch (error) {
                console.error("AI Error:", error);
            }
        }
    });
});
